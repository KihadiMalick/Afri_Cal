{
  "expo": {
    "name": "LIXUM",
    "slug": "LIXUM-APP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lixum",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E2530"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lixum.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LIXUM utilise la camera pour scanner vos repas avec Xscan.",
        "NSPhotoLibraryUsageDescription": "LIXUM accede a vos photos pour scanner vos repas.",
        "NSLocationWhenInUseUsageDescription": "LIXUM utilise votre localisation pour les defis LixVerse.",
        "NSFaceIDUsageDescription": "LIXUM utilise Face ID pour securiser votre Secret Pocket."
      }
    },
    "android": {
      "package": "com.malick2977.LIXUMAPP",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E2530"
      },
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#1E2530"
      },
      "navigationBar": {
        "backgroundColor": "#1E2530",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "LIXUM utilise la camera pour scanner vos repas."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LIXUM utilise votre position pour les defis LixVerse."
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "LIXUM accede a vos photos pour scanner vos repas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aa185157-efcb-4568-880f-393dac60e425"
      }
    },
    "owner": "malick2977",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aa185157-efcb-4568-880f-393dac60e425"
    }
  }
}
